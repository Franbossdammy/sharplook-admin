        {"name": "Pay Subscription", "request": {"method": "POST", "header": [{"key": "Content-Type", "value": "application/json"}], "body": {"mode": "raw", "raw": "{\"paymentReference\":\"SUB-PAY-123\"}"}, "url": {"raw": "{{base_url}}/subscriptions/:subscriptionId/pay", "host": ["{{base_url}}"], "path": ["subscriptions", ":subscriptionId", "pay"], "variable": [{"key": "subscriptionId", "value": ""}]}}},
