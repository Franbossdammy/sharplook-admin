      "item": [
        {"name": "Create In-Shop Subscription", "request": {"method": "POST", "header": [{"key": "Content-Type", "value": "application/json"}], "body": {"mode": "raw", "raw": "{\"type\":\"in_shop\"}"}, "url": {"raw": "{{base_url}}/subscriptions", "host": ["{{base_url}}"], "path": ["subscriptions"]}, "description": "₦5,000/month, 0% commission"}},
        {"name": "Create Home Service Subscription", "request": {"method": "POST", "header": [{"key": "Content-Type", "value": "application/json"}], "body": {"mode": "raw", "raw": "{\"type\":\"home_service\"}"}, "url": {"raw": "{{base_url}}/subscriptions", "host": ["{{base_url}}"], "path": ["subscriptions"]}, "description": "FREE, 10% commission"}},
