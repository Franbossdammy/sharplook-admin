        {"name": "Cancel Subscription", "request": {"method": "POST", "header": [{"key": "Content-Type", "value": "application/json"}], "body": {"mode": "raw", "raw": "{\"reason\":\"No longer needed\"}"}, "url": {"raw": "{{base_url}}/subscriptions/cancel", "host": ["{{base_url}}"], "path": ["subscriptions", "cancel"]}}}
